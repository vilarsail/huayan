    "occurrences": [
      {
        "file": "12.txt",
        "index": 3957,
        "context": "婆世界次下方，有世界，名为：关𨷲。如来于彼，或名：发起焰，或名"
      },
      {
        "file": "12.txt",
        "index": 7807,
        "context": "！此娑婆世界所言苦圣谛者，彼关𨷲世界中，或名：败坏相，或名：如"
      },
      {
        "file": "12.txt",
        "index": 7893,
        "context": "。诸佛子！所言苦集圣谛者，彼关𨷲世界中，或名：行，或名：愤毒，"
      },
      {
        "file": "12.txt",
        "index": 7971,
        "context": "。诸佛子！所言苦灭圣谛者，彼关𨷲世界中，或名：无积集，或名：不"
      },
      {
        "file": "12.txt",
        "index": 8055,
        "context": "诸佛子！所言苦灭道圣谛者，彼关𨷲世界中，或名：安隐行，或名：离"
      },
      {
        "file": "12.txt",
        "index": 8129,
        "context": "：救济，或名：胜行。诸佛子！关𨷲世界说四圣谛，有如是等四百亿十"
      }
    ]
  },
